datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String
  googleId  String?  @unique
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wallet Wallet?
  transactions Transaction[]

  // 🩺 Medical Information
  bloodGroup     String?
  genotype       String?
  medicalHistory String[]
  allergies      String[]

  // 🧬 Lifestyle
  smoker     Boolean? @default(false)
  alcoholUse String?
  drugUse    Boolean? @default(false)

  // 🔗 Relations
  appointments    Appointment[]
  favoriteDoctors FavoriteDoctor[]
}

enum TransactionType {
TOPUP
PAYMENT
REFUND
}


enum TransactionChannel {
CARD
BANK_TRANSFER
USSD
WALLET
}


enum TransactionStatus {
PENDING
SUCCESS
FAILED
REFUNDED
}



model Wallet {
id String @id @default(cuid())
user User @relation(fields: [userId], references: [id])
userId String @unique
balance BigInt @default(0) // store in kobo (subunits)
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}


model Transaction {
id String @id @default(cuid())
user User @relation(fields: [userId], references: [id])
userId String
type TransactionType
channel TransactionChannel
amount BigInt // stored in kobo
currency String @default("NGN")
status TransactionStatus @default(PENDING)
reference String? @unique
paystackResponse Json?
meta Json?
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}


model Doctor {
  id             Int      @id @default(autoincrement())
  name           String
  specialty      String[]
  rating         Float?   @default(0)
  bio            String?
  availableHours Json?
  fee            Int      @default(3000)
  createdAt      DateTime @default(now())

  // 🔗 Relations
  appointments Appointment[]
  favoritedBy  FavoriteDoctor[]
}

model Appointment {
  id       Int    @id @default(autoincrement())
  doctor   Doctor @relation(fields: [doctorId], references: [id])
  doctorId Int

  user   User   @relation(fields: [userId], references: [id])
  userId String

  date DateTime
  time String

  videoCallUrl String
  status       String @default("pending")

  createdAt DateTime @default(now())
}

model Hospital {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  phone     String?
  email     String?
  specialty String[]
  createdAt DateTime @default(now())
}

model Lab {
  id        Int      @id @default(autoincrement())
  name      String
  services  String
  address   String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
}

model Pharmacy {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
}

model FavoriteDoctor {
  id       Int    @id @default(autoincrement())
  userId   String
  doctorId Int

  user   User   @relation(fields: [userId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])
}
